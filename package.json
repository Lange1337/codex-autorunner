{
  "name": "codex-autorunner-ui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "lint": "pnpm web:lint",
    "typecheck": "pnpm web:typecheck",
    "build": "pnpm web:build",
    "web:dev": "pnpm --filter @codex-autorunner/web-hub dev",
    "web:build": "pnpm --filter @codex-autorunner/web-hub build",
    "web:typecheck": "pnpm --filter @codex-autorunner/web-hub typecheck",
    "web:lint": "pnpm --filter @codex-autorunner/web-hub lint",
    "web:test": "pnpm --filter @codex-autorunner/web-hub test",
    "web:smoke:hub": ".venv/bin/python scripts/pma_live_hub_smoke.py",
    "web:smoke:journeys": ".venv/bin/python scripts/web_ui_smoke_journeys.py"
  }
}
