    {
      "kind": "run_command_update",
      "actor": "user",
      "surfaces": ["telegram"],
      "payload": {
        "text": "/newt",
        "thread_id": 55,
        "update_id": 77
      }
    }
  ],
  "transcript_invariants": [
    {
      "kind": "contains_text",
      "surfaces": ["discord", "telegram"],
      "params": {
        "text": "Reset branch"
      }
    }
  ],
  "contract_links": {
